{
  "info": {
    "name": "UBL Fraud Detection API",
    "description": "API endpoints for UBL Fraud Detection System - Supports CSV and Excel (.xlsx) files - Currency: PKR",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/",
          "host": ["{{base_url}}"],
          "path": [""]
        },
        "description": "Check if the API is running"
      }
    },
    {
      "name": "Generate Rules",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": "sample_transactions.csv",
              "description": "Transaction data file (CSV or Excel .xlsx)"
            },
            {
              "key": "input_date",
              "value": "31/12/2023",
              "type": "text",
              "description": "Reference date in DD/MM/YYYY format"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/api/v1/generate-rules",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "generate-rules"]
        },
        "description": "Generate fraud detection rules from historical data (supports CSV and Excel files)"
      }
    },
    {
      "name": "List Rules",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/rules/list",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "rules", "list"]
        },
        "description": "List all available rules files"
      }
    },
    {
      "name": "Detect Fraud",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": "sample_transactions.csv",
              "description": "Transaction data file (CSV or Excel .xlsx)"
            },
            {
              "key": "detection_date",
              "value": "01/01/2024",
              "type": "text",
              "description": "Date to detect fraud (DD/MM/YYYY)"
            },
            {
              "key": "rules_date",
              "value": "31/12/2023",
              "type": "text",
              "description": "Date of rules file to use (DD/MM/YYYY)"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/api/v1/detect-fraud",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "detect-fraud"]
        },
        "description": "Detect fraud in transactions using pre-generated rules (supports CSV and Excel files)"
      }
    },
    {
      "name": "Dashboard Metrics",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": "fraud_detection_results.csv",
              "description": "Fraud detection results file (CSV or Excel .xlsx, output from detect-fraud endpoint)"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/api/v1/dashboard-metrics",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "dashboard-metrics"]
        },
        "description": "Generate comprehensive dashboard metrics from fraud detection results. Returns summary metrics, key indicators, actionable alerts, fraud distribution, top accounts, amount distribution (PKR), temporal analysis, and transaction details. Supports CSV and Excel files."
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ]
}
